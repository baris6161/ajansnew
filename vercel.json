{
  "redirects": [
    { "source": "/crm/nfc", "destination": "/nfc", "permanent": true },
    { "source": "/crm/nfc/(.*)", "destination": "/nfc", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}

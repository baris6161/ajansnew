# Öffentliche Basis URL ohne Slash am Ende (Canonical, Open Graph, Sitemap Build)
# Beispiel: https://www.ihre-domain.de
VITE_SITE_URL=

# ── SMTP (für /api/reviews/submit — Yorum-E-Mails) ─────────────
# Pflichtfelder: SMTP_HOST, SMTP_USER, SMTP_PASS
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Empfänger-Adresse (Standard: ajanskoeln@gmail.com)
REVIEW_EMAIL_TO=ajanskoeln@gmail.com

# Absender-Adresse (Standard: gleich wie SMTP_USER)
REVIEW_EMAIL_FROM=
